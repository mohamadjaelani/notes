        <mxCell id="Y3M4Bx-OVit1wf5kS7Ky-1" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;scenario_script&lt;/h1&gt;&lt;div style=&quot;color: rgb(187, 190, 191); background-color: rgb(18, 19, 20); font-family: &amp;quot;Droid Sans Mono&amp;quot;, monospace; font-size: 14px; line-height: 19px; white-space: pre;&quot;&gt;&lt;div&gt;{&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;sourceProtocolObject&quot;&lt;/span&gt;:{&lt;/div&gt;&lt;div&gt;        &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;type&quot;&lt;/span&gt;:&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&quot;http&quot;&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;        &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;port&quot;&lt;/span&gt;:&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&quot;8080&quot;&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;        &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;path&quot;&lt;/span&gt;:&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&quot;/test&quot;&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;        &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;authentication&quot;&lt;/span&gt;:{&lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;type&quot;&lt;/span&gt;:&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&quot;basic &amp;lt;base 64 encoded&amp;gt;&quot;&lt;/span&gt;}&lt;/div&gt;&lt;div&gt;    },&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;destinationProtocolObject&quot;&lt;/span&gt;:{&lt;/div&gt;&lt;div&gt;        &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;type&quot;&lt;/span&gt;:&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&quot;http&quot;&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;        &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;host&quot;&lt;/span&gt;:&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&quot;http://localhost&quot;&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;        &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;port&quot;&lt;/span&gt;:&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&quot;8888&quot;&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;        &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;path&quot;&lt;/span&gt;:&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&quot;/result&quot;&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;        &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;authentication&quot;&lt;/span&gt;:[&lt;/div&gt;&lt;div&gt;            {&lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;seq&quot;&lt;/span&gt;:&lt;span style=&quot;color: #b5cea8;&quot;&gt;1&lt;/span&gt;, &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;type&quot;&lt;/span&gt;:&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&quot;basic &amp;lt;base 64 encoded&amp;gt;&quot;&lt;/span&gt;},&lt;/div&gt;&lt;div&gt;            {&lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;seq&quot;&lt;/span&gt;:&lt;span style=&quot;color: #b5cea8;&quot;&gt;2&lt;/span&gt;, &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;type&quot;&lt;/span&gt;:&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&quot;bearer &amp;lt;bearer token&amp;gt;&quot;&lt;/span&gt;}&lt;/div&gt;&lt;div&gt;        ]&lt;/div&gt;&lt;div&gt;    },&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;sourceStructure&quot;&lt;/span&gt;:&lt;/div&gt;&lt;div&gt;    [&lt;/div&gt;&lt;div&gt;        {&lt;/div&gt;&lt;div&gt;            &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;fName&quot;&lt;/span&gt;:&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&quot;name&quot;&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;            &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;dType&quot;&lt;/span&gt;:&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&quot;str&quot;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;        },&lt;/div&gt;&lt;div&gt;        {&lt;/div&gt;&lt;div&gt;            &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;fName&quot;&lt;/span&gt;:&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&quot;age&quot;&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;            &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;dType&quot;&lt;/span&gt;:&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&quot;int&quot;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;        },&lt;/div&gt;&lt;div&gt;        {&lt;/div&gt;&lt;div&gt;            &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;fName&quot;&lt;/span&gt;:&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&quot;occupation&quot;&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;            &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;dType&quot;&lt;/span&gt;:&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&quot;str&quot;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;        },&lt;/div&gt;&lt;div&gt;        {&lt;/div&gt;&lt;div&gt;            &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;fName&quot;&lt;/span&gt;:&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&quot;dob&quot;&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;            &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;dType&quot;&lt;/span&gt;:&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&quot;date&quot;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;        }&lt;/div&gt;&lt;div&gt;    ],&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;destStructure&quot;&lt;/span&gt;:&lt;/div&gt;&lt;div&gt;    [&lt;/div&gt;&lt;div&gt;        {&lt;/div&gt;&lt;div&gt;            &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;fNama&quot;&lt;/span&gt;:&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&quot;nama&quot;&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;            &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;dType&quot;&lt;/span&gt;:&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&quot;str&quot;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;        },&lt;/div&gt;&lt;div&gt;        {&lt;/div&gt;&lt;div&gt;            &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;fNama&quot;&lt;/span&gt;:&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&quot;umur&quot;&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;            &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;dType&quot;&lt;/span&gt;:&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&quot;int&quot;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;        },&lt;/div&gt;&lt;div&gt;        {&lt;/div&gt;&lt;div&gt;            &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;fNama&quot;&lt;/span&gt;:&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&quot;pekerjaan&quot;&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;            &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;dType&quot;&lt;/span&gt;:&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&quot;str&quot;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;        },&lt;/div&gt;&lt;div&gt;        {&lt;/div&gt;&lt;div&gt;            &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;fNama&quot;&lt;/span&gt;:&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&quot;tgl lahir&quot;&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;            &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;dType&quot;&lt;/span&gt;:&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&quot;date&quot;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;        }&lt;/div&gt;&lt;div&gt;    ],&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;mapping&quot;&lt;/span&gt;:&lt;/div&gt;&lt;div&gt;    [&lt;/div&gt;&lt;div&gt;        {&lt;/div&gt;&lt;div&gt;            &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;sName&quot;&lt;/span&gt;:&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&quot;name&quot;&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;            &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;dName&quot;&lt;/span&gt;:&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&quot;nama&quot;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;        },&lt;/div&gt;&lt;div&gt;        {&lt;/div&gt;&lt;div&gt;            &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;sName&quot;&lt;/span&gt;:&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&quot;age&quot;&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;            &lt;span style=&quot;color: #7ee787;&quot;&gt;&quot;dName&quot;&lt;/span&gt;:&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&